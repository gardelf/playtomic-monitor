# ─── Base de datos ────────────────────────────────────────────────────────────
# MySQL / TiDB connection string
# Formato: mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# ─── Autenticación ────────────────────────────────────────────────────────────
# Secreto para firmar las cookies de sesión JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET=

# ─── OAuth (Manus Auth) ───────────────────────────────────────────────────────
# URL del servidor OAuth de Manus (no cambiar si usas Manus Auth)
OAUTH_SERVER_URL=

# OpenID del propietario de la aplicación (se obtiene desde el panel de Manus)
OWNER_OPEN_ID=

# ─── Entorno ──────────────────────────────────────────────────────────────────
# En Railway se establece automáticamente como "production"
NODE_ENV=production

# Puerto del servidor (Railway lo asigna automáticamente via $PORT)
# No es necesario definirlo manualmente en Railway
# PORT=3000
